{
  "title": "My Documentation",
  "url": "https://bthanhtung.github.io/my-docmd",
  "src": "docs",
  "out": "site",
  "theme": {
    "name": "default"
  },
  "plugins": {
    "seo": {
      "defaultDescription": "Documentation built with docmd."
    },
    "llms": {}
  },
  "navigation": [
    {
      "title": "Home",
      "path": "/",
      "icon": "home"
    },
    {
      "title": "Technical Guides",
      "icon": "server",
      "collapsible": true,
      "children": [
        {
          "title": "Architecture",
          "path": "/technical/architecture"
        },
        {
          "title": "API Guidelines",
          "path": "/technical/api-guidelines"
        },
        {
          "title": "Database Schema",
          "path": "/technical/database-schema"
        }
      ]
    },
    {
      "title": "Interview Questions",
      "path": "/interview-question",
      "icon": "book-open"
    },
    {
      "title": "Resources",
      "icon": "feather",
      "collapsible": false,
      "children": [
        {
          "title": "Documentation",
          "path": "external:https://docs.docmd.io",
          "external": true
        },
        {
          "title": "Configuration Guide",
          "path": "external:https://docs.docmd.io/configuration/overview",
          "external": true
        }
      ]
    }
  ]
}